<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RedisVL.Tutorial.ViewModels"
        xmlns:v="using:RedisVL.Tutorial.Views"
        x:Class="RedisVL.Tutorial.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RedisVL for .NET"
        Width="900" Height="700"
        Background="{DynamicResource BgPrimaryBrush}">

    <DockPanel>
        <!-- Redis Red accent bar -->
        <Border DockPanel.Dock="Top"
                Height="4"
                Background="{DynamicResource RedisRedBrush}" />

        <!-- App header -->
        <Border DockPanel.Dock="Top"
                Padding="16,12"
                Background="{DynamicResource BgPrimaryBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="RedisVL"
                           FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource RedisRedBrush}" />
                <TextBlock Text="for .NET"
                           FontSize="24" FontWeight="Light"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <v:SettingsPanel DockPanel.Dock="Top"
                         DataContext="{Binding Settings}"
                         Margin="16,0,16,8" />

        <v:MetricsDashboardView DockPanel.Dock="Bottom"
                                 DataContext="{Binding MetricsDashboard}"
                                 Margin="8,0,8,0" />

        <TabControl ItemsSource="{Binding Sections}"
                    SelectedItem="{Binding SelectedSection}"
                    Margin="8">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>

