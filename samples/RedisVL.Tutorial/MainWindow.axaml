<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:RedisVL.Tutorial.ViewModels"
        xmlns:v="using:RedisVL.Tutorial.Views"
        x:Class="RedisVL.Tutorial.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="RedisVL .NET Tutorial"
        Width="900" Height="700">

    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="RedisVL .NET Tutorial"
                   FontSize="24" FontWeight="Bold"
                   Margin="16,12" />

        <v:VectorizerConfig DockPanel.Dock="Top"
                            DataContext="{Binding VectorizerConfig}"
                            Margin="16,0,16,8" />

        <TabControl ItemsSource="{Binding Sections}"
                    SelectedItem="{Binding SelectedSection}"
                    Margin="8">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding}" />
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>

