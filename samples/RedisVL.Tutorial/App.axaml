<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vl="clr-namespace:Zafiro.Avalonia.ViewLocators;assembly=Zafiro.Avalonia"
             x:Class="RedisVL.Tutorial.App">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://RedisVL.Tutorial/Themes/RedisTheme.axaml" />
    </Application.Styles>
    <Application.DataTemplates>
        <vl:DataTypeViewLocator />
    </Application.DataTemplates>
</Application>

