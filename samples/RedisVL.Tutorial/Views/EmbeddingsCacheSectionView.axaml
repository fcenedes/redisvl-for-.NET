<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedisVL.Tutorial.ViewModels"
             xmlns:z="clr-namespace:Zafiro.Avalonia.Controls;assembly=Zafiro.Avalonia"
             x:Class="RedisVL.Tutorial.Views.EmbeddingsCacheSectionView"
             x:DataType="vm:EmbeddingsCacheSectionViewModel">
    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">

            <TextBlock Text="Embeddings Cache" FontSize="18" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap"
                       Text="Cache raw embeddings by text and model name. Uses the current vectorizer to generate embeddings." />

            <!-- Store Section -->
            <z:HeaderedContainer Header="Store Embedding">
                <StackPanel Spacing="8">
                    <TextBox Text="{Binding Text}" Watermark="Text to embed (e.g. Hello world)" />
                    <TextBox Text="{Binding ModelName}" Watermark="Model name (e.g. demo-model)" />
                    <Button Content="Set (generate &amp; cache)" Command="{Binding Set}" />
                </StackPanel>
            </z:HeaderedContainer>

            <!-- Retrieve Section -->
            <z:HeaderedContainer Header="Retrieve / Check / Drop">
                <StackPanel Spacing="8">
                    <TextBlock Text="Uses the Text and Model Name from above."
                               FontSize="12" Opacity="0.7" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Get" Command="{Binding Get}" />
                        <Button Content="Check Exists" Command="{Binding Exists}" />
                        <Button Content="Drop" Command="{Binding Drop}" />
                    </StackPanel>
                </StackPanel>
            </z:HeaderedContainer>

            <!-- Batch Section -->
            <z:HeaderedContainer Header="Batch Operations">
                <StackPanel Spacing="8">
                    <TextBox Text="{Binding BatchTexts}"
                             Watermark="Comma-separated texts (e.g. apple, banana, cherry)" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="MSet (batch store)" Command="{Binding MSet}" />
                        <Button Content="MGet (batch retrieve)" Command="{Binding MGet}" />
                    </StackPanel>
                </StackPanel>
            </z:HeaderedContainer>

            <!-- Output -->
            <TextBlock Text="Output:" FontWeight="SemiBold" />
            <TextBox Text="{Binding Output}" IsReadOnly="True" AcceptsReturn="True"
                     Height="140" TextWrapping="Wrap" />

            <Button Content="Clear All Cache Entries" Command="{Binding Clear}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>

