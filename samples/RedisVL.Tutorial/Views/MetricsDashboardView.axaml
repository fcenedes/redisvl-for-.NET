<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedisVL.Tutorial.ViewModels"
             x:Class="RedisVL.Tutorial.Views.MetricsDashboardView"
             x:DataType="vm:MetricsDashboardViewModel">

    <Border Padding="16,10" CornerRadius="5"
            BorderBrush="{DynamicResource BorderLightBrush}"
            BorderThickness="1,1,1,0"
            Background="{DynamicResource BgPrimaryBrush}">
        <StackPanel Spacing="8">

            <!-- Header row -->
            <DockPanel>
                <TextBlock Text="📊 METRICS DASHBOARD"
                           FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
                <Button Content="Reset"
                        Command="{Binding ResetCommand}"
                        Classes="Secondary"
                        HorizontalAlignment="Right"
                        Padding="10,4"
                        FontSize="11" />
            </DockPanel>

            <!-- No data message -->
            <TextBlock Text="Ask questions in the Semantic Cache tab to see live metrics."
                       FontSize="12" FontStyle="Italic"
                       Foreground="{DynamicResource TextMutedBrush}"
                       IsVisible="{Binding !HasData}" />

            <!-- Metrics cards row -->
            <UniformGrid Columns="4" Rows="1"
                         IsVisible="{Binding HasData}">

                <!-- Hit Rate Card -->
                <Border Margin="0,0,4,0" Padding="10,6" CornerRadius="5"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="2">
                        <TextBlock Text="HIT RATE" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding HitRateDisplay}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource SavingsGreenBrush}" />
                    </StackPanel>
                </Border>

                <!-- Savings Card -->
                <Border Margin="2,0" Padding="10,6" CornerRadius="5"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="2">
                        <TextBlock Text="SAVINGS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding SavingsDisplay}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource SavingsGreenBrush}" />
                    </StackPanel>
                </Border>

                <!-- API Cost Card -->
                <Border Margin="2,0" Padding="10,6" CornerRadius="5"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="2">
                        <TextBlock Text="API COST" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding ApiCostDisplay}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Questions Card -->
                <Border Margin="4,0,0,0" Padding="10,6" CornerRadius="5"
                        BorderBrush="{DynamicResource BorderLightBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="2">
                        <TextBlock Text="QUESTIONS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                        <TextBlock Text="{Binding QuestionsDisplay}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource RedisRedBrush}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Detail row -->
            <StackPanel Orientation="Horizontal" Spacing="16"
                        IsVisible="{Binding HasData}">
                <!-- Cache/API counts -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Cache:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="{Binding CacheHitsDisplay}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SavingsGreenBrush}" />
                    <TextBlock Text="hits" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="API:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="{Binding CacheMissesDisplay}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock Text="calls" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Tokens:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="{Binding TokensDisplay}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>

                <!-- Separator -->
                <TextBlock Text="│" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />

                <!-- Performance -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="⚡ Cache avg:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="{Binding CacheTimeDisplay}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SavingsGreenBrush}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="🌐 API avg:" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                    <TextBlock Text="{Binding ApiTimeDisplay}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>

