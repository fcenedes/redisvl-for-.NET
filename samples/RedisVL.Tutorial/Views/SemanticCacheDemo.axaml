<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RedisVL.Tutorial.Views.SemanticCacheDemo">
    <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Semantic Cache Demo" FontSize="18" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap"
                       Text="Cache LLM responses and retrieve them by semantic similarity. Uses a CustomTextVectorizer with a simple hash-based embedding for demonstration." />

            <!-- Store Section -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Store a Response" FontWeight="SemiBold" />
                    <TextBox Name="StorePrompt" Watermark="Prompt (e.g. What is Redis?)" />
                    <TextBox Name="StoreResponse" Watermark="Response" AcceptsReturn="True" Height="80" />
                    <Button Name="StoreButton" Content="Store" Click="OnStoreClick" />
                </StackPanel>
            </Border>

            <!-- Check Section -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Check Cache" FontWeight="SemiBold" />
                    <TextBox Name="CheckPrompt" Watermark="Query prompt (e.g. Tell me about Redis)" />
                    <Button Name="CheckButton" Content="Check" Click="OnCheckClick" />
                </StackPanel>
            </Border>

            <!-- Results -->
            <TextBlock Text="Output:" FontWeight="SemiBold" />
            <TextBox Name="Output" IsReadOnly="True" AcceptsReturn="True" Height="120"
                     TextWrapping="Wrap" />

            <Button Name="ClearButton" Content="Clear Cache" Click="OnClearClick" />
        </StackPanel>
    </ScrollViewer>
</UserControl>

