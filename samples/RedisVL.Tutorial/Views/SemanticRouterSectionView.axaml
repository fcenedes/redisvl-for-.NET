<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedisVL.Tutorial.ViewModels"
             x:Class="RedisVL.Tutorial.Views.SemanticRouterSectionView"
             x:DataType="vm:SemanticRouterSectionViewModel">
    <StackPanel Margin="16" Spacing="12">
        <TextBlock Text="Semantic Router" FontSize="18" FontWeight="SemiBold" />
        <TextBlock TextWrapping="Wrap"
                   Text="Route queries to different handlers based on semantic similarity." />
    </StackPanel>
</UserControl>

