<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="RedisVL.Tutorial.Views.MessageHistoryDemo">
    <ScrollViewer>
        <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Message History Demo" FontSize="18" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap"
                       Text="Store conversation messages with semantic search. Uses SemanticMessageHistory with a CustomTextVectorizer to find relevant messages by meaning." />

            <!-- Add Message -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Add Message" FontWeight="SemiBold" />
                    <ComboBox Name="RoleCombo" SelectedIndex="0" Width="200">
                        <ComboBoxItem Content="user" />
                        <ComboBoxItem Content="assistant" />
                        <ComboBoxItem Content="system" />
                    </ComboBox>
                    <TextBox Name="MessageContent" Watermark="Message content" AcceptsReturn="True" Height="60" />
                    <Button Name="AddButton" Content="Add Message" Click="OnAddClick" />
                </StackPanel>
            </Border>

            <!-- Search -->
            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Search Messages" FontWeight="SemiBold" />
                    <TextBox Name="SearchQuery" Watermark="Semantic search query" />
                    <Button Name="SearchButton" Content="Search Relevant" Click="OnSearchClick" />
                    <Button Name="RecentButton" Content="Get Recent (5)" Click="OnRecentClick" />
                </StackPanel>
            </Border>

            <!-- Output -->
            <TextBlock Text="Output:" FontWeight="SemiBold" />
            <TextBox Name="Output" IsReadOnly="True" AcceptsReturn="True" Height="160"
                     TextWrapping="Wrap" />

            <Button Name="ClearButton" Content="Clear History" Click="OnClearClick" />
        </StackPanel>
    </ScrollViewer>
</UserControl>

