<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedisVL.Tutorial.ViewModels"
             x:Class="RedisVL.Tutorial.Views.VectorizerConfig"
             x:DataType="vm:VectorizerConfigViewModel">

    <Border Padding="12" CornerRadius="8"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <StackPanel Spacing="10">

            <TextBlock Text="Vectorizer Settings"
                       FontWeight="SemiBold" FontSize="14" />

            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12" Opacity="0.7"
                       TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="12">

                <StackPanel Spacing="4">
                    <TextBlock Text="Mode" FontSize="12" />
                    <ComboBox ItemsSource="{Binding AvailableModes}"
                              SelectedItem="{Binding SelectedMode}"
                              MinWidth="140" />
                </StackPanel>

                <StackPanel Spacing="4"
                            IsVisible="{Binding ShowApiKey}">
                    <TextBlock Text="{Binding ApiKeyLabel}" FontSize="12" />
                    <TextBox Text="{Binding ApiKey}"
                             PasswordChar="•"
                             Watermark="Enter your key..."
                             MinWidth="250" />
                </StackPanel>

                <Button Content="Apply"
                        Command="{Binding Apply}"
                        VerticalAlignment="Bottom"
                        Classes="accent" />

            </StackPanel>

        </StackPanel>
    </Border>

</UserControl>

