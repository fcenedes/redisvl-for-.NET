<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedisVL.Tutorial.ViewModels"
             xmlns:z="clr-namespace:Zafiro.Avalonia.Controls;assembly=Zafiro.Avalonia"
             x:Class="RedisVL.Tutorial.Views.MessageHistorySectionView"
             x:DataType="vm:MessageHistorySectionViewModel">
    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">

            <TextBlock Text="Message History" FontSize="18" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap"
                       Text="Store conversation messages with semantic search. Uses SemanticMessageHistory with vectorizer to find relevant messages by meaning." />

            <!-- Add Message -->
            <z:HeaderedContainer Header="Add Message">
                <StackPanel Spacing="8">
                    <ComboBox ItemsSource="{Binding AvailableRoles}"
                              SelectedItem="{Binding SelectedRole}"
                              MinWidth="200" />
                    <TextBox Text="{Binding MessageContent}"
                             Watermark="Message content"
                             AcceptsReturn="True"
                             Height="60" />
                    <Button Content="Add Message"
                            Command="{Binding AddMessage}"
                            Classes="Primary" />
                </StackPanel>
            </z:HeaderedContainer>

            <!-- Search -->
            <z:HeaderedContainer Header="Search Messages">
                <StackPanel Spacing="8">
                    <TextBox Text="{Binding SearchQuery}"
                             Watermark="Semantic search query" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Search Relevant"
                                Command="{Binding SearchRelevant}"
                                Classes="Primary" />
                        <Button Content="Get Recent (5)"
                                Command="{Binding GetRecent}"
                                Classes="Secondary" />
                    </StackPanel>
                </StackPanel>
            </z:HeaderedContainer>

            <!-- Output -->
            <TextBlock Text="Output:" FontWeight="SemiBold" />
            <TextBox Text="{Binding Output, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     Height="160"
                     TextWrapping="Wrap" />

            <Button Content="Clear History"
                    Command="{Binding Clear}"
                    Classes="Secondary" />

        </StackPanel>
    </ScrollViewer>
</UserControl>

