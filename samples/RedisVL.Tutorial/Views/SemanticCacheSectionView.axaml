<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:RedisVL.Tutorial.ViewModels"
             xmlns:z="clr-namespace:Zafiro.Avalonia.Controls;assembly=Zafiro.Avalonia"
             x:Class="RedisVL.Tutorial.Views.SemanticCacheSectionView"
             x:DataType="vm:SemanticCacheSectionViewModel">
    <ScrollViewer>
        <StackPanel Margin="16" Spacing="16">
            <TextBlock Text="Semantic Cache" FontSize="18" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap"
                       Text="Cache LLM responses and retrieve them by semantic similarity. In Demo mode, only exact text matches work. Switch to OpenAI or HuggingFace for true semantic matching." />

            <!-- Distance Threshold -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="Distance Threshold:" VerticalAlignment="Center" />
                <Slider Minimum="0.01" Maximum="1.0"
                        Value="{Binding DistanceThreshold}"
                        Width="200" TickFrequency="0.05" IsSnapToTickEnabled="True" />
                <TextBlock Text="{Binding DistanceThreshold, StringFormat='{}{0:F2}'}"
                           VerticalAlignment="Center" FontWeight="SemiBold" />
            </StackPanel>

            <!-- Ask LLM Section -->
            <z:HeaderedContainer Header="Ask LLM (with Semantic Cache)">
                <StackPanel Spacing="8">
                    <TextBox Watermark="Ask a question (e.g. What is Redis?)"
                             Text="{Binding AskPrompt}" />
                    <Button Content="Ask" Command="{Binding Ask}" Classes="Primary" />
                </StackPanel>
            </z:HeaderedContainer>

            <!-- Store Section -->
            <Expander Header="Manual Store Entry" IsExpanded="False">
                <StackPanel Spacing="8" Margin="0,8,0,0">
                    <TextBox Watermark="Prompt (e.g. What is Redis?)"
                             Text="{Binding StorePrompt}" />
                    <TextBox Watermark="Response"
                             AcceptsReturn="True" Height="80"
                             Text="{Binding StoreResponse}" />
                    <Button Content="Store" Command="{Binding Store}" Classes="Primary" />
                </StackPanel>
            </Expander>

            <!-- Check Section -->
            <z:HeaderedContainer Header="Check Cache">
                <StackPanel Spacing="8">
                    <TextBox Watermark="Query prompt (e.g. Tell me about Redis)"
                             Text="{Binding CheckPrompt}" />
                    <Button Content="Check" Command="{Binding Check}" Classes="Primary" />
                </StackPanel>
            </z:HeaderedContainer>

            <!-- Output -->
            <TextBlock Text="Output:" FontWeight="SemiBold" />
            <TextBox IsReadOnly="True" AcceptsReturn="True" Height="140"
                     TextWrapping="Wrap"
                     Text="{Binding Output}" />

            <Button Content="Clear Cache" Command="{Binding Clear}" Classes="Secondary" />
        </StackPanel>
    </ScrollViewer>
</UserControl>

